#Implementation of the Needleman–Wunsch global alignment algorithm using dynamic programming and backtracking to compare biological sequences end-to-end
#The algorithm first builds a dynamic programming matrix, where each cell stores the best possible alignment score up to that position. After filling the matrix, the code performs backtracking to reconstruct the aligned sequences, including gaps where necessary.

v = ""

w = ""


MATCH_REWARD = 1
MISMATCH_PENALTY = 1
INDEL_PENALTY = 5


def score(a, b):
    if a == b:
        return MATCH_REWARD
    return -MISMATCH_PENALTY


def global_alignment(v, w):
    n = len(v)
    m = len(w)

    dp = [[0] * (m + 1) for _ in range(n + 1)]

    # Initialize first column
    for i in range(1, n + 1):
        dp[i][0] = dp[i - 1][0] - INDEL_PENALTY

    # Initialize first row
    for j in range(1, m + 1):
        dp[0][j] = dp[0][j - 1] - INDEL_PENALTY

    # Fill DP table
    for i in range(1, n + 1):
        for j in range(1, m + 1):
            match_or_mismatch = dp[i - 1][j - 1] + score(v[i - 1], w[j - 1])
            deletion = dp[i - 1][j] - INDEL_PENALTY
            insertion = dp[i][j - 1] - INDEL_PENALTY

            dp[i][j] = max(match_or_mismatch, deletion, insertion)

    return dp[n][m], dp


def construct(v, w):
    best_score, dp = global_alignment(v, w)

    aligned_v = []
    aligned_w = []

    i = len(v)
    j = len(w)

    while i > 0 or j > 0:
        if i > 0 and j > 0 and dp[i][j] == dp[i - 1][j - 1] + score(v[i - 1], w[j - 1]):
            aligned_v.append(v[i - 1])
            aligned_w.append(w[j - 1])
            i -= 1
            j -= 1

        elif i > 0 and dp[i][j] == dp[i - 1][j] - INDEL_PENALTY:
            aligned_v.append(v[i - 1])
            aligned_w.append("-")
            i -= 1

        else:
            aligned_v.append("-")
            aligned_w.append(w[j - 1])
            j -= 1

    aligned_v = "".join(reversed(aligned_v))
    aligned_w = "".join(reversed(aligned_w))

    return best_score, aligned_v, aligned_w


best_score, aligned_v, aligned_w = construct(v, w)

print(best_score)
print(aligned_v)
print(aligned_w)
